{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Icon": "imgs/actions/cloudflare-status",
      "Name": "Cloudflare Status",
      "PropertyInspectorPath": "ui/cloudflare-status.html",
      "States": [
        {
          "Image": "imgs/actions/cloudflare-status",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display Cloudflare system status",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.status"
    },
    {
      "Icon": "imgs/actions/worker-deployment-status",
      "Name": "Worker Deployment Status",
      "PropertyInspectorPath": "ui/worker-deployment-status.html",
      "States": [
        {
          "Image": "imgs/actions/worker-deployment-status",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display deployment status of a Cloudflare Worker",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.worker-deployment-status"
    },
    {
      "Icon": "imgs/actions/ai-gateway-metric",
      "Name": "AI Gateway Metric",
      "PropertyInspectorPath": "ui/ai-gateway-metric.html",
      "States": [
        {
          "Image": "imgs/actions/ai-gateway-metric",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display metrics from a Cloudflare AI Gateway",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.ai-gateway-metric"
    },
    {
      "Icon": "imgs/actions/worker-analytics",
      "Name": "Worker Analytics",
      "PropertyInspectorPath": "ui/worker-analytics.html",
      "States": [
        {
          "Image": "imgs/actions/worker-analytics",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display analytics metrics from a Cloudflare Worker",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.worker-analytics"
    },
    {
      "Icon": "imgs/actions/pages-deployment-status",
      "Name": "Pages Deployment",
      "PropertyInspectorPath": "ui/pages-deployment-status.html",
      "States": [
        {
          "Image": "imgs/actions/pages-deployment-status",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display deployment status of a Cloudflare Pages project",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.pages-deployment-status"
    },
    {
      "Icon": "imgs/actions/dns-record-monitor",
      "Name": "DNS Record Monitor",
      "PropertyInspectorPath": "ui/dns-record-monitor.html",
      "States": [
        {
          "Image": "imgs/actions/dns-record-monitor",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Monitor a specific DNS record in a Cloudflare zone",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.dns-record-monitor"
    },
    {
      "Icon": "imgs/actions/zone-analytics",
      "Name": "Zone Analytics",
      "PropertyInspectorPath": "ui/zone-analytics.html",
      "States": [
        {
          "Image": "imgs/actions/zone-analytics",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display analytics metrics for a Cloudflare zone",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.zone-analytics"
    },
    {
      "Icon": "imgs/actions/r2-storage-metric",
      "Name": "R2 Storage Metric",
      "PropertyInspectorPath": "ui/r2-storage-metric.html",
      "States": [
        {
          "Image": "imgs/actions/r2-storage-metric",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display storage metrics for a Cloudflare R2 bucket",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.r2-storage-metric"
    },
    {
      "Icon": "imgs/actions/d1-database-metric",
      "Name": "D1 Database Metric",
      "PropertyInspectorPath": "ui/d1-database-metric.html",
      "States": [
        {
          "Image": "imgs/actions/d1-database-metric",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display analytics metrics for a Cloudflare D1 database",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.d1-database-metric"
    },
    {
      "Icon": "imgs/actions/kv-namespace-metric",
      "Name": "KV Namespace Metric",
      "PropertyInspectorPath": "ui/kv-namespace-metric.html",
      "States": [
        {
          "Image": "imgs/actions/kv-namespace-metric",
          "ShowTitle": false
        }
      ],
      "Tooltip": "Display analytics metrics for a Cloudflare Workers KV namespace",
      "UserTitleEnabled": false,
      "UUID": "com.pedrofuentes.cloudflare-utilities.kv-namespace-metric"
    }
  ],
  "Author": "Pedro Fuentes",
  "Category": "Cloudflare Utilities",
  "CategoryIcon": "imgs/plugin/category-icon",
  "CodePath": "bin/plugin.js",
  "Description": "A set of utilities to display information from Cloudflare on your Stream Deck",
  "Icon": "imgs/plugin/marketplace",
  "Name": "Cloudflare Utilities",
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    },
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "6.9"
  },
  "URL": "https://github.com/pedrofuentes/stream-deck-cloudflare-utilities",
  "UUID": "com.pedrofuentes.cloudflare-utilities",
  "Version": "1.2.1.0"
}